# ViajaJapón — variables de entorno (plantilla). Copia este archivo a `.env.local` y rellena.
# `.env.local` está ignorado por git (nunca subas claves ni enlaces de tracking al repo).
#
# AFILIADOS — pega aquí el enlace de tracking COMPLETO que te da cada panel de afiliado.
# Mientras estén vacías, los enlaces apuntan a la URL canónica (funcionan pero NO pagan).
# Tras editar este archivo hay que reconstruir/redeploy (las páginas son estáticas).

AFF_CIVITATIS=
AFF_KLOOK=
AFF_IATI=
AFF_HEYMONDO=
AFF_HOLAFLY=
AFF_AIRALO=
AFF_SKYSCANNER=
# JR Pass: enlace de un REVENDEDOR con programa (NO japanrailpass.net, que paga 0€).
AFF_JRPASS=
AFF_REVOLUT=
# Preparados, sin activar todavía (dar de alta en el programa de afiliados antes de rellenar).
AFF_BOOKING=
AFF_GETYOURGUIDE=

# EMAIL — MailerLite (Fase 0, captura de suscriptores).
# API key desde MailerLite → Integrations → API. El Group ID desde la URL del grupo.
MAILERLITE_API_KEY=
MAILERLITE_GROUP_ID=

# CRON — secreto para proteger /api/cron/refresh (genera uno largo y aleatorio).
CRON_SECRET=
